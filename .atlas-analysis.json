  "keyFeatures": [
    "Weekly solver payout calculation with COW token and native ETH rewards",
    "Multi-network support (Mainnet, Gnosis, Arbitrum, Base, Avalanche, Polygon, BNB, Linea, Plasma, Ink)",
    "Dune Analytics integration for on-chain data aggregation",
    "PostgreSQL orderbook analytics database integration",
    "Automated multisend transaction posting to Gnosis Safe",
    "Overdraft tracking and management via on-chain contract",
    "Slippage and network fee accounting per solver",
    "Partner and protocol fee distribution",
    "Service fee deduction for CoW DAO",
    "Slack notification integration for payout status"
  ],
